<?xml version="1.0" encoding="UTF-8"?>
<mujoco model="Franka Robot">
    
    <!-- Include all the component files -->
    <include file="./franka_assets/assets.xml"/>
    <include file="./franka_assets/basic_scene.xml"/>
    <include file="./franka_assets/actuator.xml"/>
    
    <!-- World body with the robot -->
    <worldbody>
        <!-- Add the Franka robot -->
        <body name="robot" pos="0 0 0">
            <include file="./franka_assets/chain.xml"/>
        </body>
    </worldbody>
    
    <!-- Home/pretension keyframe: the Franka "ready" pose. Single source of truth
         for the initial/home state (applied by teleop and reset_to_home).
         7 arm joints at the ready pose + 2 gripper finger joints at 0. -->
    <keyframe>
        <key name="pretension"
             qpos="0 -0.7853981633974483 0 -2.356194490192345 0 1.5707963267948966 0.7853981633974483 0 0"
             ctrl="0 -0.7853981633974483 0 -2.356194490192345 0 1.5707963267948966 0.7853981633974483 0 0"/>
    </keyframe>

</mujoco>