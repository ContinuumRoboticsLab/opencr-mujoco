# Generated TDCR models: ignore all XML except the hand-authored base
# scenes. Scenes referenced by teleop/viewer configs are regenerated on
# first use from their configs/generation/ source (generate.ensure_scene)
*.xml
!assets/franka_assets/*.xml
!assets/franka_scene*.xml
!docs/scenes/**/*.xml

